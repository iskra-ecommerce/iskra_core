{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" id="button-save" data-bs-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa-solid fa-save"></i></button>
        <a href="{{ back }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-cog"></i> {{ text_settings }}</div>
      <div class="card-body">
        <form id="form-iskra-core" action="{{ save }}" method="post" data-oc-toggle="ajax">
          <ul class="nav nav-tabs">
            <li class="nav-item"><a href="#tab-general" class="nav-link active" data-bs-toggle="tab">{{ tab_settings }}</a></li>
            <li class="nav-item"><a href="#tab-logs" class="nav-link" data-bs-toggle="tab">{{ tab_logs }}</a></li>
            <li class="nav-item"><a href="#tab-backups" class="nav-link" data-bs-toggle="tab">{{ tab_backups }}</a></li>
            <li class="nav-item"><a href="#tab-migrations" class="nav-link" data-bs-toggle="tab">{{ tab_migrations }}</a></li>
            <li class="nav-item"><a href="#tab-integrity" class="nav-link" data-bs-toggle="tab">{{ tab_integrity }}</a></li>
          </ul>

          <div class="tab-content">
            <!-- General Settings -->
            <div class="tab-pane active" id="tab-general">
              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-logging-enabled">{{ entry_logging_enabled }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="checkbox" name="iskra_core_logging_enabled" value="1" id="input-logging-enabled" class="form-check-input"{% if iskra_core_logging_enabled %} checked{% endif %}>
                    <label class="form-check-label" for="input-logging-enabled">{% if iskra_core_logging_enabled %}{{ text_enabled }}{% else %}{{ text_disabled }}{% endif %}</label>
                  </div>
                  <div class="form-text">{{ help_logging_enabled }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-log-level">{{ entry_log_level }}</label>
                <div class="col-sm-10">
                  <select name="iskra_core_log_level" id="input-log-level" class="form-select">
                    <option value="debug"{% if iskra_core_log_level == 'debug' %} selected{% endif %}>{{ level_debug }}</option>
                    <option value="info"{% if iskra_core_log_level == 'info' %} selected{% endif %}>{{ level_info }}</option>
                    <option value="warning"{% if iskra_core_log_level == 'warning' %} selected{% endif %}>{{ level_warning }}</option>
                    <option value="error"{% if iskra_core_log_level == 'error' %} selected{% endif %}>{{ level_error }}</option>
                    <option value="critical"{% if iskra_core_log_level == 'critical' %} selected{% endif %}>{{ level_critical }}</option>
                  </select>
                  <div class="form-text">{{ help_log_level }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-log-retention">{{ entry_log_retention_days }}</label>
                <div class="col-sm-10">
                  <input type="number" name="iskra_core_log_retention_days" value="{{ iskra_core_log_retention_days }}" id="input-log-retention" class="form-control" min="1" max="365">
                  <div class="form-text">{{ help_log_retention_days }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-log-limit-strategy">{{ entry_log_limit_strategy }}</label>
                <div class="col-sm-10">
                  <select name="iskra_core_log_limit_strategy" id="input-log-limit-strategy" class="form-select">
                    <option value="rows"{% if iskra_core_log_limit_strategy == 'rows' %} selected{% endif %}>rows ({{ entry_log_max_rows }})</option>
                    <option value="table_size"{% if iskra_core_log_limit_strategy == 'table_size' %} selected{% endif %}>table_size ({{ entry_log_max_size_mb }})</option>
                    <option value="disk_space"{% if iskra_core_log_limit_strategy == 'disk_space' %} selected{% endif %}>disk_space ({{ entry_log_min_disk_mb }})</option>
                  </select>
                  <div class="form-text">{{ help_log_limit_strategy }}</div>
                </div>
              </div>

              <div class="row mb-3" id="row-max-rows">
                <label class="col-sm-2 col-form-label" for="input-max-rows">{{ entry_log_max_rows }}</label>
                <div class="col-sm-10">
                  <input type="number" name="iskra_core_log_max_rows" value="{{ iskra_core_log_max_rows }}" id="input-max-rows" class="form-control" min="1000" max="10000000">
                  <div class="form-text">{{ help_log_max_rows }}</div>
                </div>
              </div>

              <div class="row mb-3" id="row-max-size">
                <label class="col-sm-2 col-form-label" for="input-max-size">{{ entry_log_max_size_mb }}</label>
                <div class="col-sm-10">
                  <input type="number" name="iskra_core_log_max_size_mb" value="{{ iskra_core_log_max_size_mb }}" id="input-max-size" class="form-control" min="100" max="102400">
                  <div class="form-text">{{ help_log_max_size_mb }}</div>
                </div>
              </div>

              <div class="row mb-3" id="row-min-disk">
                <label class="col-sm-2 col-form-label" for="input-min-disk">{{ entry_log_min_disk_mb }}</label>
                <div class="col-sm-10">
                  <input type="number" name="iskra_core_log_min_disk_mb" value="{{ iskra_core_log_min_disk_mb }}" id="input-min-disk" class="form-control" min="100" max="50000">
                  <div class="form-text">{{ help_log_min_disk_mb }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-event-bus">{{ entry_event_bus_enabled }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="checkbox" name="iskra_core_event_bus_enabled" value="1" id="input-event-bus" class="form-check-input"{% if iskra_core_event_bus_enabled %} checked{% endif %}>
                    <label class="form-check-label" for="input-event-bus">{% if iskra_core_event_bus_enabled %}{{ text_enabled }}{% else %}{{ text_disabled }}{% endif %}</label>
                  </div>
                  <div class="form-text">{{ help_event_bus }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-queue-cron">{{ entry_queue_cron_enabled }}</label>
                <div class="col-sm-10">
                  <div class="form-check form-switch form-switch-lg">
                    <input type="checkbox" name="iskra_core_queue_cron_enabled" value="1" id="input-queue-cron" class="form-check-input"{% if iskra_core_queue_cron_enabled %} checked{% endif %}>
                    <label class="form-check-label" for="input-queue-cron">{% if iskra_core_queue_cron_enabled %}{{ text_enabled }}{% else %}{{ text_disabled }}{% endif %}</label>
                  </div>
                  <div class="form-text">{{ help_queue_cron }}</div>
                </div>
              </div>

              <div class="row mb-3">
                <label class="col-sm-2 col-form-label" for="input-backup-retention">{{ entry_backup_retention_days }}</label>
                <div class="col-sm-10">
                  <input type="number" name="iskra_core_backup_retention_days" value="{{ iskra_core_backup_retention_days }}" id="input-backup-retention" class="form-control" min="1" max="365">
                  <div class="form-text">{{ help_backup_retention }}</div>
                </div>
              </div>
            </div>

            <!-- Logs Tab (Placeholder - redirects to log controller) -->
            <div class="tab-pane" id="tab-logs">
              <div class="alert alert-info">{{ text_logs }} — <a href="{{ rotate|replace({'iskra_core_log.rotate':'iskra_core_log'}) }}">Go to Logs</a></div>
            </div>

            <!-- Backups Tab -->
            <div class="tab-pane" id="tab-backups">
              <div class="row mb-3">
                <div class="col-12">
                  <button type="button" id="button-backup" class="btn btn-success"><i class="fa-solid fa-download"></i> {{ button_backup }}</button>
                  <hr>
                  <div id="backup-list">Loading backups...</div>
                </div>
              </div>
            </div>

            <!-- Migrations Tab -->
            <div class="tab-pane" id="tab-migrations">
              <div class="row mb-3">
                <div class="col-12">
                  <button type="button" id="button-run-migrations" class="btn btn-primary"><i class="fa-solid fa-play"></i> {{ button_run }}</button>
                  <button type="button" id="button-rollback" class="btn btn-warning"><i class="fa-solid fa-undo"></i> {{ button_rollback }}</button>
                  <hr>
                  <div id="migration-list">Loading migrations...</div>
                </div>
              </div>
            </div>

            <!-- Integrity Tab -->
            <div class="tab-pane" id="tab-integrity">
              <div class="row mb-3">
                <div class="col-12">
                  <button type="button" id="button-check-integrity" class="btn btn-info"><i class="fa-solid fa-check-circle"></i> {{ button_check }}</button>
                  <hr>
                  <div id="integrity-report">Click Check to run integrity report.</div>
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
const userToken = '{{ user_token }}';

// Strategy toggle
$('#input-log-limit-strategy').on('change', function() {
  const v = $(this).val();
  $('#row-max-rows').toggle(v === 'rows');
  $('#row-max-size').toggle(v === 'table_size');
  $('#row-min-disk').toggle(v === 'disk_space');
}).trigger('change');

$('#button-save').on('click', function() {
  $('#form-iskra-core').submit();
});

// Backups Tab
function loadBackups() {
  $.get('index.php?route=extension/iskra_core/module/iskra_core.listBackups&user_token=' + userToken, function(json) {
    if (json.error) { $('#backup-list').html('<div class="alert alert-danger">' + json.error + '</div>'); return; }
    if (!json.backups || json.backups.length === 0) { $('#backup-list').html('<div class="alert alert-info">{{ text_no_backups }}</div>'); return; }
    let html = '<table class="table table-bordered table-hover"><thead><tr><th>{{ column_backup_name }}</th><th>{{ column_backup_size }}</th><th>{{ column_backup_date }}</th><th>{{ text_action }}</th></tr></thead><tbody>';
    json.backups.forEach(function(b) {
      const size = (b.size / 1024 / 1024).toFixed(2) + ' MB';
      const date = new Date(b.date * 1000).toLocaleString();
      html += '<tr><td>' + b.name + '</td><td>' + size + '</td><td>' + date + '</td><td>';
      html += '<button class="btn btn-sm btn-danger delete-backup" data-name="' + b.name + '">{{ button_delete }}</button> ';
      html += '<button class="btn btn-sm btn-warning restore-backup" data-name="' + b.name + '">{{ button_restore }}</button>';
      html += '</td></tr>';
    });
    html += '</tbody></table>';
    $('#backup-list').html(html);
    bindBackupButtons();
  });
}

function bindBackupButtons() {
  $('.delete-backup').on('click', function() {
    const name = $(this).data('name');
    if (!confirm('{{ text_confirm_delete }}')) return;
    $.post('index.php?route=extension/iskra_core/module/iskra_core.deleteBackup&user_token=' + userToken, { name: name }, function(json) {
      if (json.success) { loadBackups(); }
      else if (json.error) { alert(json.error); }
    });
  });
  $('.restore-backup').on('click', function() {
    const name = $(this).data('name');
    if (!confirm('{{ text_confirm_rollback }}')) return;
    $.post('index.php?route=extension/iskra_core/module/iskra_core.restoreBackup&user_token=' + userToken, { name: name }, function(json) {
      if (json.success) { alert(json.success); }
      else if (json.error) { alert(json.error); }
    });
  });
}

$('#button-backup').on('click', function() {
  $.post('index.php?route=extension/iskra_core/module/iskra_core.createBackup&user_token=' + userToken, function(json) {
    if (json.success) { loadBackups(); }
    else if (json.error) { alert(json.error); }
  });
});

// Migrations Tab
function loadMigrations() {
  $.get('index.php?route=extension/iskra_core/module/iskra_core.listMigrations&user_token=' + userToken, function(json) {
    if (json.error) { $('#migration-list').html('<div class="alert alert-danger">' + json.error + '</div>'); return; }
    if (!json.migrations || json.migrations.length === 0) { $('#migration-list').html('<div class="alert alert-info">{{ text_no_migrations }}</div>'); return; }
    let html = '<table class="table table-bordered table-hover"><thead><tr><th>{{ column_version }}</th><th>{{ column_name }}</th><th>{{ column_status }}</th><th>{{ column_applied }}</th><th>{{ column_error }}</th></tr></thead><tbody>';
    json.migrations.forEach(function(m) {
      let statusBadge = '';
      if (m.status === 'success') statusBadge = '<span class="badge bg-success">{{ text_success_status }}</span>';
      else if (m.status === 'failed') statusBadge = '<span class="badge bg-danger">{{ text_failed }}</span>';
      else if (m.status === 'rolled_back') statusBadge = '<span class="badge bg-warning">{{ text_rolled_back }}</span>';
      else statusBadge = '<span class="badge bg-secondary">{{ text_pending }}</span>';
      html += '<tr><td>' + m.version + '</td><td>' + m.name + '</td><td>' + statusBadge + '</td><td>' + (m.applied_at ?? '-') + '</td><td>' + (m.error ?? '-') + '</td></tr>';
    });
    html += '</tbody></table>';
    $('#migration-list').html(html);
  });
}

$('#button-run-migrations').on('click', function() {
  $.post('index.php?route=extension/iskra_core/module/iskra_core.runMigrations&user_token=' + userToken, function(json) {
    if (json.success) { loadMigrations(); alert(json.success); }
    else if (json.error) { alert(json.error); }
  });
});

$('#button-rollback').on('click', function() {
  if (!confirm('{{ text_confirm_rollback }}')) return;
  $.post('index.php?route=extension/iskra_core/module/iskra_core.rollbackMigration&user_token=' + userToken, function(json) {
    if (json.success) { loadMigrations(); alert(json.success); }
    else if (json.error) { alert(json.error); }
  });
});

// Integrity Tab
$('#button-check-integrity').on('click', function() {
  $.get('index.php?route=extension/iskra_core/module/iskra_core.checkIntegrity&user_token=' + userToken, function(json) {
    if (json.error) { $('#integrity-report').html('<div class="alert alert-danger">' + json.error + '</div>'); return; }
    let html = '<table class="table table-bordered table-hover"><thead><tr><th>{{ column_table }}</th><th>{{ column_rows }}</th><th>{{ column_size }}</th><th>{{ text_status }}</th></tr></thead><tbody>';
    json.report.forEach(function(r) {
      let status = r.status === 'ok' ? '<span class="badge bg-success">{{ text_ok }}</span>' : '<span class="badge bg-danger">{{ text_error }}</span>';
      html += '<tr><td>' + r.table + '</td><td>' + (r.rows ?? '-') + '</td><td>' + (r.size ? (r.size/1024/1024).toFixed(2) + ' MB' : '-') + '</td><td>' + status + '</td></tr>';
    });
    html += '</tbody></table>';
    if (json.success) { html = '<div class="alert alert-success">' + json.success + '</div>' + html; }
    $('#integrity-report').html(html);
  });
});

// Load tabs on show
$('a[data-bs-toggle="tab"]').on('shown.bs.tab', function(e) {
  const target = $(e.target).attr('href');
  if (target === '#tab-backups') loadBackups();
  if (target === '#tab-migrations') loadMigrations();
});
</script>
{{ footer }}
