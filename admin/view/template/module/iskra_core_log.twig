{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" id="button-rotate" data-bs-toggle="tooltip" title="{{ button_rotate }}" class="btn btn-warning"><i class="fa-solid fa-sync"></i></button>
        <button type="button" id="button-delete" data-bs-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" disabled><i class="fa-solid fa-trash"></i></button>
        <a href="{{ back|default(rotate|replace({'iskra_core_log.rotate':'iskra_core'})) }}" data-bs-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a>
      </div>
      <h1>{{ heading_title }} — {{ tab_logs }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    <!-- Stats -->
    <div class="row mb-3">
      <div class="col-12">
        <div class="card">
          <div class="card-header"><i class="fa-solid fa-chart-bar"></i> Stats</div>
          <div class="card-body">
            <div class="row">
              <div class="col-md-2"><strong>{{ text_all }}:</strong> {{ stats.total }}</div>
              {% for level, count in stats.by_level %}
                <div class="col-md-2"><strong>{{ attribute(_context, 'level_' ~ level) }}:</strong> {{ count }}</div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="card mb-3">
      <div class="card-header"><i class="fa-solid fa-filter"></i> {{ text_filter }}</div>
      <div class="card-body">
        <form id="form-filter" method="get" action="{{ filter_action|default('') }}">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="row">
            <div class="col-md-2">
              <label class="form-label">{{ entry_level }}</label>
              <select name="level" class="form-select">
                <option value="">{{ text_all }}</option>
                <option value="debug"{% if filter.level == 'debug' %} selected{% endif %}>{{ level_debug }}</option>
                <option value="info"{% if filter.level == 'info' %} selected{% endif %}>{{ level_info }}</option>
                <option value="warning"{% if filter.level == 'warning' %} selected{% endif %}>{{ level_warning }}</option>
                <option value="error"{% if filter.level == 'error' %} selected{% endif %}>{{ level_error }}</option>
                <option value="critical"{% if filter.level == 'critical' %} selected{% endif %}>{{ level_critical }}</option>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_category }}</label>
              <select name="category" class="form-select">
                <option value="">{{ text_all }}</option>
                {% for cat in categories %}
                  <option value="{{ cat }}"{% if filter.category == cat %} selected{% endif %}>{{ cat }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_date_from }}</label>
              <input type="date" name="date_from" value="{{ filter.date_from }}" class="form-control">
            </div>
            <div class="col-md-2">
              <label class="form-label">{{ entry_date_to }}</label>
              <input type="date" name="date_to" value="{{ filter.date_to }}" class="form-control">
            </div>
            <div class="col-md-3">
              <label class="form-label">{{ text_search }}</label>
              <input type="text" name="search" value="{{ filter.search }}" class="form-control" placeholder="{{ text_search }}...">
            </div>
            <div class="col-md-1 d-flex align-items-end">
              <button type="submit" class="btn btn-primary w-100"><i class="fa-solid fa-filter"></i></button>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Logs Table -->
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-list"></i> {{ text_logs }}</div>
      <div class="card-body table-responsive">
        <table class="table table-bordered table-hover" id="log-table">
          <thead>
            <tr>
              <th class="text-center" style="width: 1px;"><input type="checkbox" id="select-all" class="form-check-input"></th>
              <th>{{ column_level }}</th>
              <th>{{ column_category }}</th>
              <th>{{ column_user }}</th>
              <th>{{ column_message }}</th>
              <th>{{ column_ip }}</th>
              <th>{{ column_date }}</th>
            </tr>
          </thead>
          <tbody>
            {% if logs %}
              {% for log in logs %}
                <tr>
                  <td class="text-center"><input type="checkbox" name="selected[]" value="{{ log.log_id }}" class="form-check-input log-check"></td>
                  <td>
                    {% if log.level == 'debug' %}<span class="badge bg-secondary">{{ level_debug }}</span>
                    {% elseif log.level == 'info' %}<span class="badge bg-info">{{ level_info }}</span>
                    {% elseif log.level == 'warning' %}<span class="badge bg-warning text-dark">{{ level_warning }}</span>
                    {% elseif log.level == 'error' %}<span class="badge bg-danger">{{ level_error }}</span>
                    {% elseif log.level == 'critical' %}<span class="badge bg-dark">{{ level_critical }}</span>
                    {% endif %}
                  </td>
                  <td>{{ log.category }}</td>
                  <td>{{ log.user_name|default('-') }}</td>
                  <td>{{ log.message|length > 100 ? log.message|slice(0, 100) ~ '...' : log.message }}</td>
                  <td>{{ log.ip_address|default('-') }}</td>
                  <td>{{ log.date_added }}</td>
                </tr>
              {% endfor %}
            {% else %}
              <tr><td colspan="7" class="text-center">{{ text_no_logs }}</td></tr>
            {% endif %}
          </tbody>
        </table>
      </div>
      <div class="card-footer">{{ pagination }}</div>
    </div>
  </div>
</div>

<script>
$('#select-all').on('change', function() {
  $('.log-check').prop('checked', $(this).prop('checked'));
  updateDeleteButton();
});
$('.log-check').on('change', updateDeleteButton);

function updateDeleteButton() {
  $('#button-delete').prop('disabled', $('.log-check:checked').length === 0);
}

$('#button-delete').on('click', function() {
  if (!confirm('{{ text_confirm_delete }}')) return;
  var selected = [];
  $('.log-check:checked').each(function() { selected.push($(this).val()); });
  $.ajax({
    url: '{{ delete }}',
    type: 'post',
    data: { selected: selected },
    dataType: 'json',
    success: function(json) {
      if (json.success) { location.reload(); }
      else if (json.error) { alert(json.error); }
    }
  });
});

$('#button-rotate').on('click', function() {
  if (!confirm('{{ text_confirm_delete|replace({"delete the selected items": "rotate all old logs" }) }}')) return;
  $.ajax({
    url: '{{ rotate }}',
    type: 'post',
    dataType: 'json',
    success: function(json) {
      if (json.success) { alert(json.success); location.reload(); }
      else if (json.error) { alert(json.error); }
    }
  });
});
</script>
{{ footer }}
